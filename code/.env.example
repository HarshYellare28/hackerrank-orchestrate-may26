# Copy this file to `.env` at the repository root.
# Do not commit `.env`.

# Recommended local mode: Ollama
SUPPORT_AGENT_LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b
SUPPORT_AGENT_ALLOW_HEURISTIC_FALLBACK=true

# Optional OpenAI mode, if you have API credits.
# Uncomment these and comment out the Ollama lines above.
# SUPPORT_AGENT_LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-mini
# SUPPORT_AGENT_ALLOW_HEURISTIC_FALLBACK=true
